#!/bin/zsh
# ContextEngine — Pre-commit CE Compliance Check + Secret Scanner
#
# BLOCKS commits when:
#   1. Staged files contain hardcoded passwords/API keys/secrets
#   2. Code files changed but CE docs are stale or missing
#
# Agents ignore warnings — only hard blocks prevent compliance drift.
#
# Install: cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

# Ensure standard tools are on PATH (git hooks run with minimal PATH)
export PATH="/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin:$PATH"

# ===================================================================
# Helper: locate the ContextEngine CLI
# ===================================================================
# Order: project-local node_modules → global which → none (skip policy).
# We intentionally do NOT fall back to `npx @compr/contextengine-mcp` —
# cold npx is ~2-3s on every commit; too painful for a hot path. Teams
# that want policy-driven gates should install CE in node_modules or
# globally.
find_ce_cli() {
  if [[ -x "node_modules/.bin/contextengine" ]]; then
    echo "node_modules/.bin/contextengine"
    return 0
  fi
  if command -v contextengine >/dev/null 2>&1; then
    command -v contextengine
    return 0
  fi
  echo ""
}

CE_CLI=$(find_ce_cli)
HAS_POLICY=false
[[ -f .contextengine/policy.json ]] && HAS_POLICY=true

# ===================================================================
# PHASE 0: Secret Scanner — three complementary layers
# ===================================================================
#   1. gitleaks (if installed) — industry-standard ~150-pattern ruleset.
#      Audited, maintained. Install: brew install gitleaks
#   2. CE policy-driven scan (if CLI + policy.json present) — applies
#      .contextengine/policy.json secret_patterns with paths-glob scoping
#      and severity (block | warn). Project-specific shapes that gitleaks
#      doesn't know (e.g. jwt_in_session_doc scoped to docs/sessions/**).
#   3. CE inline patterns (always) — 17 in-house regexes covering
#      Stripe/GitHub/AWS/Slack/etc + project-specific DB-password shapes
#      + the .copilot-credentials.md staging guard. Defense in depth:
#      catches whatever the first two layers missed.
#
# Each layer can block independently. First one to fail wins; later
# layers do not run.

# Layer 1: gitleaks
if command -v gitleaks >/dev/null 2>&1; then
  GITLEAKS_OUTPUT=$(gitleaks protect --staged --redact --no-banner --verbose 2>&1)
  GITLEAKS_EXIT=$?
  if [[ $GITLEAKS_EXIT -ne 0 ]]; then
    echo ""
    echo "╔═══════════════════════════════════════════════════════════╗"
    echo "║  🔒 GITLEAKS: secret(s) detected                          ║"
    echo "╠═══════════════════════════════════════════════════════════╣"
    echo "$GITLEAKS_OUTPUT" | head -25
    echo "║  Secrets belong in .env or .copilot-credentials.md       ║"
    echo "║  ❌ COMMIT BLOCKED — remove secrets first                 ║"
    echo "╚═══════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
  fi
fi

# Layer 2: CE policy-driven scan (added 2026-06 — P1 #4 part 3)
# The CLI exits 0 cleanly when no policy file exists, so the HAS_POLICY
# gate is a perf optimization, not a correctness requirement.
if [[ -n "$CE_CLI" && "$HAS_POLICY" == "true" ]]; then
  if ! "$CE_CLI" hook secret-scan; then
    # CLI already printed the violation list + wrote hook.block to audit log
    exit 1
  fi
fi

# Layer 3: CE inline patterns (always)
SECRET_PATTERNS=(
  'sshpass -p [^*"$]|Hardcoded sshpass password (use SSHPASS env var)'
  'whsec_[A-Za-z0-9]{20,}|Stripe webhook secret (use .env)'
  'sk_live_[A-Za-z0-9]{20,}|Stripe live secret key (use .env)'
  'sk_test_[A-Za-z0-9]{20,}|Stripe test secret key (use .env)'
  'AIzaSy[A-Za-z0-9_-]{30,}|Google API key (use .env)'
  'gsk_[A-Za-z0-9]{20,}|Groq API key (use .env)'
  'ghp_[A-Za-z0-9]{36,}|GitHub personal access token (use .env)'
  'glpat-[A-Za-z0-9_-]{20,}|GitLab personal access token (use .env)'
  'xoxb-[0-9]{10,}|Slack bot token (use .env)'
  'xoxp-[0-9]{10,}|Slack user token (use .env)'
  'AKIA[A-Z0-9]{16}|AWS access key ID (use .env)'
  'pk_live_[A-Za-z0-9]{20,}|Stripe publishable live key (use .env)'
  'SG\.[A-Za-z0-9_-]{22}\.[A-Za-z0-9_-]{43}|SendGrid API key (use .env)'
  'Cr0wlr_Pr0d_[A-Za-z0-9!@#$%^&*_]+|Production DB password (use .copilot-credentials.md)'
  'C0ldEm@il_[A-Za-z0-9!@#$%^&*_]+|COLDemail DB password (use .copilot-credentials.md)'
  'password.*=.*[A-Za-z0-9!@#$%^&*]{8,}|Possible hardcoded password in assignment'
)

SKIP_FILES='(\.copilot-credentials\.md|\.env$|\.env\.local|\.env\.example|pre-commit-secrets|pre-commit$)'
STAGED_DIFF=$(git diff --cached --diff-filter=ACMR -U0 2>/dev/null)
STAGED_FILE_LIST=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null)

SECRET_VIOLATIONS=0
SECRET_DETAILS=""

if [[ -n "$STAGED_DIFF" ]]; then
  FILTERED_DIFF=""
  CURRENT_FILE=""
  SKIP_CURRENT=false

  while IFS= read -r line; do
    if [[ "$line" =~ ^diff\ --git ]]; then
      CURRENT_FILE=$(echo "$line" | sed 's|.*b/||')
      if echo "$CURRENT_FILE" | grep -qE "$SKIP_FILES"; then
        SKIP_CURRENT=true
      else
        SKIP_CURRENT=false
      fi
    fi
    if [[ "$SKIP_CURRENT" == false ]]; then
      FILTERED_DIFF+="$line"$'\n'
    fi
  done <<< "$STAGED_DIFF"

  for entry in "${SECRET_PATTERNS[@]}"; do
    PATTERN="${entry%%|*}"
    DESCRIPTION="${entry##*|}"
    MATCHES=$(echo "$FILTERED_DIFF" | grep -E '^\+[^+]' | grep -E "$PATTERN" 2>/dev/null)
    if [[ -n "$MATCHES" ]]; then
      ((SECRET_VIOLATIONS++))
      SECRET_DETAILS+="  🔑 $DESCRIPTION\n"
    fi
  done
fi

if echo "$STAGED_FILE_LIST" | grep -q '\.copilot-credentials\.md'; then
  ((SECRET_VIOLATIONS++))
  SECRET_DETAILS+="  🚫 .copilot-credentials.md is staged! Run: git reset HEAD .copilot-credentials.md\n"
fi

if [[ $SECRET_VIOLATIONS -gt 0 ]]; then
  echo ""
  echo "╔═══════════════════════════════════════════════════════════╗"
  echo "║  🔒 SECRET SCANNER: $SECRET_VIOLATIONS violation(s) found                    ║"
  echo "╠═══════════════════════════════════════════════════════════╣"
  echo -e "$SECRET_DETAILS"
  echo "║  Secrets belong in .env or .copilot-credentials.md       ║"
  echo "║  ❌ COMMIT BLOCKED — remove secrets first                 ║"
  echo "╚═══════════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

# ===================================================================
# PHASE 1: Doc Freshness
# ===================================================================
# Two paths:
#   - Policy-driven (preferred): when policy.json is present, the
#     diff-aware doc_coverage rules ARE the source of truth. The
#     legacy 4h wall-clock check is suppressed — it was the workaround
#     pattern (touching SKILLS.md to reset the clock).
#   - Legacy fallback: when no policy is authored, the original 4h
#     wall-clock check on copilot-instructions.md / SKILLS.md / SCORE.md
#     runs unchanged. Repos without a policy keep working exactly as
#     before. Migration is opt-in by adding .contextengine/policy.json.

if [[ -n "$CE_CLI" && "$HAS_POLICY" == "true" ]]; then
  if ! "$CE_CLI" hook doc-coverage; then
    # CLI already printed violations + wrote hook.block to audit log
    exit 1
  fi
  # Policy path is authoritative. Skip the legacy check.
  exit 0
fi

# Legacy path: 4-hour wall-clock check (only when no policy authored).
# This logic is being retired — author .contextengine/policy.json to
# replace it with diff-aware coverage.

CODE_EXTS="ts|tsx|js|jsx|py|rs|go|java|rb|php|vue|svelte|css|scss|html"
STAGED_CODE=$(git diff --cached --name-only | grep -E "\.($CODE_EXTS)$" | head -1)

# If no code files staged, skip all checks (docs-only commit is fine)
if [[ -z "$STAGED_CODE" ]]; then
  exit 0
fi

WARNINGS=0
NOW=$(date +%s)
STALE_HOURS=4

warn() {
  echo "⚠️  CE: $1"
  ((WARNINGS++))
}

check_freshness() {
  local file="$1"
  local label="$2"

  local found_paths=()
  for candidate_path in "$file" ".github/$file" ".github/instructions/$file"; do
    if [[ -f "$candidate_path" ]]; then
      found_paths+=("$candidate_path")
    fi
  done

  if [[ ${#found_paths[@]} -eq 0 ]]; then
    warn "$label — NOT FOUND (create it!)"
    return
  fi

  for fp in "${found_paths[@]}"; do
    if git diff --cached --name-only | grep -q "$fp"; then
      return
    fi
  done

  local newest_mtime=0
  for fp in "${found_paths[@]}"; do
    local mtime=$(stat -f %m "$fp" 2>/dev/null || stat -c %Y "$fp" 2>/dev/null)
    if [[ -n "$mtime" && $mtime -gt $newest_mtime ]]; then
      newest_mtime=$mtime
    fi
  done

  if [[ $newest_mtime -gt 0 ]]; then
    local age_hours=$(( (NOW - newest_mtime) / 3600 ))
    if [[ $age_hours -gt $STALE_HOURS ]]; then
      warn "$label — last updated ${age_hours}h ago (not in this commit)"
    fi
  fi
}

check_freshness "copilot-instructions.md" "copilot-instructions.md"
check_freshness "SKILLS.md" "SKILLS.md"
check_freshness "SCORE.md" "SCORE.md"

LEARNINGS_FILE="$HOME/.contextengine/learnings.json"
if [[ -f "$LEARNINGS_FILE" ]]; then
  LEARN_MTIME=$(stat -f %m "$LEARNINGS_FILE" 2>/dev/null || stat -c %Y "$LEARNINGS_FILE" 2>/dev/null)
  if [[ -n "$LEARN_MTIME" ]]; then
    LEARN_AGE=$(( (NOW - LEARN_MTIME) / 3600 ))
    if [[ $LEARN_AGE -gt 8 ]]; then
      warn "No learnings saved in ${LEARN_AGE}h — did you forget save_learning?"
    fi
  fi
fi

if [[ $WARNINGS -gt 0 ]]; then
  echo ""
  echo "╔═══════════════════════════════════════════════════════╗"
  echo "║  ContextEngine: $WARNINGS CE compliance violation(s)          ║"
  echo "║  Code changed but CE docs are stale or missing.      ║"
  echo "║  Update: copilot-instructions, SKILLS, SCORE         ║"
  echo "║                                                       ║"
  echo "║  ❌ COMMIT BLOCKED — update docs first                ║"
  echo "║  💡 Author .contextengine/policy.json for diff-aware  ║"
  echo "║     coverage instead of wall-clock staleness.        ║"
  echo "╚═══════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

exit 0
