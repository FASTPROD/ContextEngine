    "git-hooks",
    "pre-commit",
    "secret-scanning",
    "fleet",
    "context",
    "knowledge-base",
    "developer-tools"
  ],
  "author": {
    "name": "PROD LLC (operating brand of CSS LLC, Swiss, est. 2005)",
    "email": "yannick@compr.ch",
    "url": "https://github.com/FASTPROD/ContextEngine/blob/main/docs/about.md"
  },
