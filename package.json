{
  "name": "@compr/opscontext-mcp",
  "version": "2.1.2",
  "description": "OpsContext for AI Agents \u2014 read-only fleet visibility (PM2/nginx/Docker/git/cron) + tamper-evident audit log + policy-as-code hooks. The ops + compliance layer Claude Code can't grow natively.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "opscontext": "dist/cli.js",
