{
  "name": "contextengine",
  "displayName": "OpsContext — AI Agent Compliance",
  "description": "Protocol Firewall + durable memory for AI coding agents. Your AI sessions end clean, not chaotic — OpsContext ensures agents save learnings, commit code, and update docs.",
  "version": "0.8.1",
  "publisher": "css-llc",
  "license": "BSL-1.1",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/FASTPROD/ContextEngine.git"
  },
  "homepage": "https://www.npmjs.com/package/@compr/opscontext-mcp",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "mcp",
    "claude-code",
    "claude",
    "copilot",
    "cursor",
    "ai-agents",
    "ops",
    "observability",
    "audit-log",
    "compliance",
    "policy-as-code",
    "context",
    "session",
    "knowledge-base"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "contextengine.commitAll",
        "title": "OpsContext: Commit All Changes",
        "icon": "$(git-commit)"
      },
      {
        "command": "contextengine.showStatus",
        "title": "OpsContext: Show Session Status"
      },
      {
        "command": "contextengine.endSession",
        "title": "OpsContext: End Session Checklist"
      },
      {
        "command": "contextengine.search",
        "title": "OpsContext: Search Knowledge Base"
      },
      {
        "command": "contextengine.showInfo",
        "title": "OpsContext: What We Check",
        "icon": "$(info)"
      },
      {
        "command": "contextengine.sync",
        "title": "OpsContext: Sync Docs",
        "icon": "$(sync)"
      },
      {
        "command": "contextengine.scoreHtml",
        "title": "OpsContext: Generate HTML Score Report (PRO)",
        "icon": "$(graph)"
      }
    ],
    "chatParticipants": [
      {
        "id": "contextengine.agent",
        "fullName": "OpsContext",
        "name": "contextengine",
        "description": "AI agent compliance — session status, uncommitted changes, enforcement reminders, knowledge search",
        "isSticky": false,
        "commands": [
          {
            "name": "status",
            "description": "Show session health: uncommitted changes, session state, enforcement score"
          },
          {
            "name": "commit",
            "description": "Stage and commit all changes across workspace projects"
          },
          {
            "name": "search",
            "description": "Search the OpsContext knowledge base"
          },
          {
            "name": "remind",
            "description": "Show the full enforcement checklist and what's missing"
          },
          {
            "name": "sync",
            "description": "Check documentation freshness and find stale docs"
          }
        ]
      }
    ],
    "configuration": {
      "title": "OpsContext",
      "properties": {
        "contextengine.gitCheckInterval": {
          "type": "number",
          "default": 120,
          "description": "How often (in seconds) to check for uncommitted git changes"
        },
        "contextengine.enableNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notification warnings for uncommitted changes"
        },
        "contextengine.enableStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show session health in the status bar"
        },
        "contextengine.autoCommitReminder": {
          "type": "boolean",
          "default": true,
          "description": "Remind to commit after file saves accumulate without a git commit"
        },
        "contextengine.maxDirtyFilesBeforeWarning": {
          "type": "number",
          "default": 5,
          "description": "Number of uncommitted files before showing a warning"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src/",
    "package": "npx @vscode/vsce package",
    "publish": "npx @vscode/vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.93.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^3.0.0"
  }
}
